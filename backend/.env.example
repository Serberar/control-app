# Base de datos
DB_NAME=control_parental
DB_USER=control_user
DB_PASSWORD=cambia_esta_password_segura

# Rutas de datos exteriores (fuera del contenedor)
# Puedes usar rutas absolutas a tu disco externo o NAS
DB_DATA_PATH=./data/postgres
DB_WAL_PATH=./data/wal_archive

# JWT — genera valores aleatorios largos para producción
JWT_SECRET=cambia_este_secreto_jwt_muy_largo_y_aleatorio
JWT_REFRESH_SECRET=cambia_este_secreto_refresh_diferente_al_anterior
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Servidor
PORT=3000
NODE_ENV=production
